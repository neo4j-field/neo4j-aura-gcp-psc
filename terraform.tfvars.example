# ---------------------------------------------------------------------------
# Copy this file to terraform.tfvars and fill in the required values.
# terraform.tfvars is gitignored; do not commit it.
# ---------------------------------------------------------------------------

# Required. The consumer GCP project that will host the PSC endpoint.
consumer_project_id = "my-org-neo4j-consumer"

# Consumer region and zone. For lowest latency and to avoid Premium Tier,
# match the region of your Aura instance. Same-region PSC is recommended.
consumer_region = "us-central1"
consumer_zone   = "us-central1-a"

# Networking mode. Set create_network = true to let Terraform build a new
# VPC, subnet, and firewall rules. Set create_network = false (recommended
# for a first deployment) to reuse an existing VPC and subnet, for example
# the GCP default VPC.
create_network        = false
existing_network_name = "default"
existing_subnet_name  = "default"

# Required. PSC service attachment URI from the Aura Console. Aura labels
# this the "Private Link service name". Both the short form and the full
# https://www.googleapis.com/compute/v1/... URL form are accepted.
neo4j_service_attachment = "https://www.googleapis.com/compute/v1/projects/ni-production-rd1p/regions/us-central1/serviceAttachments/db-ingress-private"

# Required. The orchestrator subdomain from the Aura Console. The wildcard
# DNS record created will be *.<neo4j_orch_subdomain>.neo4j.io and will
# resolve to the PSC endpoint internal IP.
neo4j_orch_subdomain = "production-orch-NNNN"

# Names for the reserved IP and forwarding rule. Defaults are usually fine.
psc_ip_name       = "neo4j-psc-ip"
psc_endpoint_name = "neo4j-psc-endpoint"

# ---------------------------------------------------------------------------
# Windows browser VM (optional, disabled by default). Enable only if you
# want to click through the Neo4j Browser UI from inside the VPC. The GCP
# Connectivity Test alone is sufficient to validate the PSC path; this VM
# adds Microsoft licensing cost and boot time, so leave it off unless you
# specifically need the web UI.
# ---------------------------------------------------------------------------
enable_windows_browser_vm = false
windows_vm_name           = "neo4j-test-vm-win"
windows_vm_machine_type   = "n2-standard-2"
windows_vm_public_ip      = false

# Extra labels merged on top of the default neo4j-psc/managed-by labels.
extra_labels = {
  environment = "dev"
  owner       = "platform-data"
}
