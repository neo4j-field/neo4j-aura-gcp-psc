# ---------------------------------------------------------------------------
# Copy this file to terraform.tfvars and fill in the required values.
# terraform.tfvars is gitignored; do not commit it.
# ---------------------------------------------------------------------------

# Required. The consumer GCP project that will host the PSC endpoint.
consumer_project_id = "my-org-neo4j-consumer"

# Consumer region and zone. For lowest latency and to avoid Premium Tier,
# match the region of your Aura instance. Same-region PSC is recommended.
consumer_region = "us-central1"
consumer_zone   = "us-central1-a"

# Networking mode. Set create_network = true to let Terraform build a new
# VPC, subnet, and firewall rules. Set create_network = false (recommended
# for a first deployment) to reuse an existing VPC and subnet, for example
# the GCP default VPC.
create_network        = false
existing_network_name = "default"
existing_subnet_name  = "default"

# Required. PSC service attachment URI from the Aura Console. Aura labels
# this the "Private Link service name". Both the short form and the full
# https://www.googleapis.com/compute/v1/... URL form are accepted.
neo4j_service_attachment = "https://www.googleapis.com/compute/v1/projects/ni-production-rd1p/regions/us-central1/serviceAttachments/db-ingress-private"

# Required. Full orchestrator DNS name from the Aura Console wizard
# Step 2 of 3 ("DNS Name"). Paste verbatim, including .neo4j.io. Terraform
# creates an apex A record at this name and a wildcard A record at *.<name>,
# both pointing at the PSC endpoint internal IP.
neo4j_orch_dns_name = "production-orch-NNNN.neo4j.io"

# Names for resources Terraform creates. Defaults are usually fine.
psc_ip_name              = "neo4j-psc-ip"
psc_endpoint_name        = "neo4j-psc-endpoint"
dns_response_policy_name = "neo4j-psc-rpz"

# ---------------------------------------------------------------------------
# Per-resource create/reuse toggles. Defaults all create. Flip a toggle to
# false and set the matching existing_*_name to attach to a pre-existing
# resource. Common reasons:
#   - re-running after a partial apply where one resource already exists
#   - sharing a single Cloud DNS response policy across multiple Aura
#     instances in the same VPC (set create_dns_response_policy = false and
#     point existing_dns_response_policy_name at the policy you keep)
# ---------------------------------------------------------------------------
# create_psc_ip                     = true
# existing_psc_ip_name              = ""
# create_psc_endpoint               = true
# existing_psc_endpoint_name        = ""
# create_dns_response_policy        = true
# existing_dns_response_policy_name = ""

# When sharing one response policy across multiple Aura instances, override
# the rule names to keep them unique within the shared policy.
# dns_apex_rule_name     = "neo4j-apex-prod0792"
# dns_wildcard_rule_name = "neo4j-wildcard-prod0792"

# Extra labels merged on top of the default neo4j-psc/managed-by labels.
extra_labels = {
  environment = "dev"
  owner       = "platform-data"
}
